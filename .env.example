# ─── Site ───────────────────────────────────────────────────────────────────
# Canonical production URL (no trailing slash). Used for metadata, OG, sitemap.
NEXT_PUBLIC_SITE_URL=https://launchfive-studio.web.app

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Leave blank to disable. Analytics only loads in production builds.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=

# ─── Site Verification (optional) ─────────────────────────────────────────────
# Paste the verification token (the content value from the HTML <meta> tag),
# NOT the full tag. Leave blank to skip that platform. All values are read at
# build time and emitted as meta tags in the <head>, so they survive deploys.
#
# Google Search Console:
#   Search Console → Settings → Ownership verification → HTML tag → copy the
#   content="..." value.
NEXT_PUBLIC_VERIFICATION_GOOGLE=
# Bing Webmaster Tools:
#   Bing Webmaster Tools → Verify → Meta tag → copy the content="..." value.
NEXT_PUBLIC_VERIFICATION_BING=
# Yandex Webmaster:
#   Yandex Webmaster → Site management → Meta tag verification → copy content.
NEXT_PUBLIC_VERIFICATION_YANDEX=
# Pinterest Site Verification:
#   Pinterest Business → Settings → Claim → HTML tag → copy content.
NEXT_PUBLIC_VERIFICATION_PINTEREST=
# Facebook Domain Verification:
#   Business Manager → Brand Safety → Domains → select domain → copy the
#   content="..." value from the meta tag.
NEXT_PUBLIC_VERIFICATION_FACEBOOK=

# ─── Firebase Configuration ───────────────────────────────────────────────────
# These values are safe to expose in client-side code — they are NOT secret keys.
# Firebase security is handled by Firestore Security Rules and Authentication.
